{
  "title": "CapsLock->Esc + RightControl toggle IME (stable)",
  "rules": [
    {
      "description": "Caps Lock -> Escape",
      "manipulators": [
        {
          "type": "basic",
          "from": { "key_code": "caps_lock", "modifiers": { "optional": ["any"] } },
          "to": [{ "key_code": "escape" }]
        }
      ]
    },
    {
      "description": "Right Control: EN(ABC) -> CN(SCIM.ITABC)",
      "manipulators": [
        {
          "type": "basic",
          "from": { "key_code": "right_control", "modifiers": { "optional": ["any"] } },
          "conditions": [
            {
              "type": "input_source_if",
              "input_sources": [
                { "input_source_id": "com.apple.keylayout.ABC" }
              ]
            }
          ],
          "to_if_alone": [
            {
              "select_input_source": {
                "input_source_id": "com.apple.inputmethod.SCIM.ITABC"
              }
            },
            { "key_code": "left_shift" }
          ]
        }
      ]
    },
    {
      "description": "Right Control: CN(SCIM.ITABC) -> EN(ABC)",
      "manipulators": [
        {
          "type": "basic",
          "from": { "key_code": "right_control", "modifiers": { "optional": ["any"] } },
          "conditions": [
            {
              "type": "input_source_if",
              "input_sources": [
                { "input_source_id": "com.apple.inputmethod.SCIM.ITABC" }
              ]
            }
          ],
          "to_if_alone": [
            {
              "select_input_source": {
                "input_source_id": "com.apple.keylayout.ABC"
              }
            },
            { "key_code": "left_shift" }
          ]
        }
      ]
    }
  ]
}
