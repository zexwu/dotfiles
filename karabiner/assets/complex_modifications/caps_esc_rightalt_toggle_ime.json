{
  "title": "CapsLock->Esc + RightAlt toggle IME (tap only)",
  "rules": [
    {
      "description": "Caps Lock -> Escape",
      "manipulators": [
        {
          "type": "basic",
          "from": { "key_code": "caps_lock", "modifiers": { "optional": ["any"] } },
          "to": [{ "key_code": "escape" }]
        }
      ]
    },
    {
      "description": "Right Option tap toggles between CN (SCIM.ITABC) and EN (ABC) using a variable",
      "manipulators": [
        {
          "type": "basic",
          "from": { "key_code": "right_option", "modifiers": { "optional": ["any"] } },
          "conditions": [
            { "type": "variable_if", "name": "ime_is_cn", "value": 0 }
          ],
          "to_if_alone": [
            { "set_variable": { "name": "ime_is_cn", "value": 1 } },
            { "select_input_source": { "input_source_id": "com.apple.inputmethod.SCIM.ITABC" } }
          ]
        },
        {
          "type": "basic",
          "from": { "key_code": "right_option", "modifiers": { "optional": ["any"] } },
          "conditions": [
            { "type": "variable_if", "name": "ime_is_cn", "value": 1 }
          ],
          "to_if_alone": [
            { "set_variable": { "name": "ime_is_cn", "value": 0 } },
            { "select_input_source": { "input_source_id": "com.apple.keylayout.ABC" } }
          ]
        }
      ]
    }
  ]
}
